DATABASE_URL="file:./dev.db"
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Google Maps JavaScript API key (Maps JS + Places libraries).
# Enables the interactive restaurant map and address autocomplete on /restaurants.
# Distance sorting and "Use my location" work without it. Exposed to the browser,
# so restrict the key by HTTP referrer / API in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
